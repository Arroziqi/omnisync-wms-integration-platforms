# OmniSync Environment Variables Example
# Copy this file to .env and fill in the values before starting the project.
# Never commit the actual .env file to version control.

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development

# ──────────────────────────────────────────────
# Docker — Service Port Mappings (host ports)
# ──────────────────────────────────────────────
API_PORT=3001
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ──────────────────────────────────────────────
# PostgreSQL (used by both Docker and DATABASE_URL)
# ──────────────────────────────────────────────
POSTGRES_USER=omnisync
POSTGRES_PASSWORD=omnisync_secret
POSTGRES_DB=omnisync_db

# Constructed from the above — update host when connecting outside Docker
DATABASE_URL="postgresql://omnisync:omnisync_secret@localhost:5432/omnisync_db?schema=public"

# ──────────────────────────────────────────────
# Redis (Queues & Caching)
# ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="1d"

# ──────────────────────────────────────────────
# Frontend — Public API URL (accessible from browser)
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api

# ──────────────────────────────────────────────
# Marketplace Integrations
# ──────────────────────────────────────────────
TIKTOK_APP_KEY="your-tiktok-app-key"
TIKTOK_APP_SECRET="your-tiktok-app-secret"

SHOPEE_PARTNER_ID="your-shopee-partner-id"
SHOPEE_PARTNER_KEY="your-shopee-partner-key"

LAZADA_APP_KEY="your-lazada-app-key"
LAZADA_APP_SECRET="your-lazada-app-secret"
