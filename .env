# OmniSync Environment Variables Example
# Copy this file to .env and fill in the values before starting the project.
# Never commit the actual .env file to version control.

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development

# ──────────────────────────────────────────────
# Docker — Service Port Mappings (host ports)
# ──────────────────────────────────────────────
API_PORT=3001
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ──────────────────────────────────────────────
# PostgreSQL (used by both Docker and DATABASE_URL)
# ──────────────────────────────────────────────
POSTGRES_USER=omnisync
POSTGRES_PASSWORD=omnisync_secret
POSTGRES_DB=omnisync_db

# Constructed from the above — update host when connecting outside Docker
DATABASE_URL="postgresql://postgres:root@localhost:5432/omnisync_db?schema=public"

# Database logging (true to enable raw SQL query logging, false/omit to keep logs clean)
DB_LOGGING=false

# ──────────────────────────────────────────────
# Redis (Queues & Caching)
# ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="1d"

# ──────────────────────────────────────────────
# Frontend — Public API URL (accessible from browser)
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ──────────────────────────────────────────────
# Marketplace Integrations
# ──────────────────────────────────────────────
TIKTOK_APP_KEY="your-tiktok-app-key"
TIKTOK_APP_SECRET="your-tiktok-app-secret"

SHOPEE_PARTNER_ID="your-shopee-partner-id"
SHOPEE_PARTNER_KEY="your-shopee-partner-key"

LAZADA_APP_KEY="your-lazada-app-key"
LAZADA_APP_SECRET="your-lazada-app-secret"

# ──────────────────────────────────────────────
# Queue Processing (BullMQ / US 6.2)
# ──────────────────────────────────────────────
# Number of concurrent workers processing the order sync queue
QUEUE_CONCURRENCY=5
# Maximum retry attempts per job before moving to DLQ
SYNC_JOB_MAX_ATTEMPTS=5

# Webhook Secrets (HMAC-SHA256 validation per marketplace)
TIKTOK_WEBHOOK_SECRET="your-tiktok-webhook-secret"
SHOPEE_WEBHOOK_SECRET="your-shopee-webhook-secret"
LAZADA_WEBHOOK_SECRET="your-lazada-webhook-secret"

# Marketplace API Rate Limits (calls per window)
TIKTOK_RATE_LIMIT=40
SHOPEE_RATE_LIMIT=100
LAZADA_RATE_LIMIT=100

# Throttler rate limiting overrides for development/E2E
THROTTLE_TTL=1
THROTTLE_LIMIT=100000
BYPASS_THROTTLE=true
